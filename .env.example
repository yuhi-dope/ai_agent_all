# =============================================================================
# シャチョツー 統合環境変数
# 3プロジェクト共通: shachotwo-app / shachotwo-マーケAI / shachotwo-契約AI
# =============================================================================
#
# ローカル起動手順:
#
#   1. このファイルをコピー: cp .env.example .env
#   2. .env に各APIキーを記入
#   3. Python仮想環境を有効化:
#        source .venv/bin/activate
#   4. バックエンド起動 (ターミナル1):
#        cd shachotwo-app && python -m uvicorn main:app --reload --port 8000
#   5. フロントエンド起動 (ターミナル2):
#        cd shachotwo-app/frontend && npm run dev
#   6. ブラウザで http://localhost:3000 にアクセス
#
# 必須キー: SUPABASE_URL, SUPABASE_ANON_KEY, SUPABASE_SERVICE_ROLE_KEY,
#           SUPABASE_JWT_SECRET, GEMINI_API_KEY, VOYAGE_API_KEY
#

# =============================================================================
# 共通（全プロジェクトで使用）
# =============================================================================

# ---- Supabase ----
SUPABASE_URL=https://dkkiokjwfcukjjhkiqkn.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ---- LLM ----
GEMINI_API_KEY=
ANTHROPIC_API_KEY=               # フォールバック用
LLM_PROVIDER=gemini

# ---- Embedding ----
VOYAGE_API_KEY=

# =============================================================================
# shachotwo-app 専用
# =============================================================================

# App
APP_ENV=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000
BASE_URL=http://localhost:8000

# Auth
REQUIRE_AUTH=true
DEVELOPER_EMAILS=

# Redis
REDIS_URL=redis://localhost:6379

# GCP
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=asia-northeast1
GCP_SECRET_PROJECT_ID=

# DB直接接続（マイグレーション用）
DATABASE_URL=

# トークン暗号化
TOKEN_ENCRYPTION_KEY=

# =============================================================================
# マーケAI + 契約AI 共通
# =============================================================================

# Google APIs（Sheets / Gmail / Calendar 用サービスアカウント）
GOOGLE_CREDENTIALS_PATH=credentials.json

# Sender
SENDER_NAME=杉本 雄飛
SENDER_EMAIL=
SENDER_PHONE=
COMPANY_NAME=シャチョツー
WEBSITE_URL=https://shachotwo.com

# URLs
LP_BASE_URL=http://localhost:8080
APP_BASE_URL=http://localhost:3000

# =============================================================================
# マーケAI 専用
# =============================================================================

# Google Sheets（営業リスト）
GOOGLE_SHEETS_SPREADSHEET_ID=

# gBizINFO（法人情報API）
GBIZINFO_API_TOKEN=

# Proxy（フォーム大量送信時のIP分散・optional）
PROXY_URL=

# =============================================================================
# 契約AI 専用
# =============================================================================

# CloudSign（電子契約）
CLOUDSIGN_CLIENT_ID=
CLOUDSIGN_TOKEN=

# Stripe（決済）
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STARTER_PRICE_ID=
STRIPE_GROWTH_PRICE_ID=
