NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# ローカルでは未設定推奨。クライアントは同一オリジン /api/v1 へ送り、next.config の rewrites が FastAPI（BACKEND_URL）へ転送する（CORS 不要）。
# localhost:8000 をここに書くとクロスオリジンになり OPTIONS が増え、バックエンド未起動時に pending しやすい。
# NEXT_PUBLIC_API_URL=https://your-api.example.com/api/v1
